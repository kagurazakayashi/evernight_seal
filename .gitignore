### Dart ###
# 參閱 https://www.dartlang.org/guides/libraries/private-files

# 由 pub 建立的檔案與目錄
.dart_tool/
.packages
# 若正在建置應用程式，您可能希望將 pubspec.lock 納入版本控制
pubspec.lock

# 由 dartdoc 建立的目錄
# 若未在本機產生文件，可以移除此行。
doc/api/

# dotenv 環境變數檔案
.env*

# 避免提交產生的 JavaScript 檔案：
*.dart.js
*.info.json      # 由 --dump-info 旗標產生。
*.js             # 由 dart2js 產生時。若專案包含以 JavaScript
                 # 撰寫的原始檔，請勿指定 *.js。
*.js_
*.js.deps
*.js.map

.flutter-plugins
.flutter-plugins-dependencies

### Dart Patch ###
# dotenv 環境變數檔案
.env

